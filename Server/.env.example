# Server
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# MongoDB
MONGO_URI=mongodb+srv://ai_based_apple_website:ai_based_apple_website@cluster0.f7czkam.mongodb.net/?appName=Cluster0

# Auth
JWT_SECRET=replace_with_a_long_random_string
JWT_EXPIRES_IN=7d
COOKIE_NAME=apple_store_token

# Admin bootstrap (used only by the seed script)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change_this_password

# AI (Anthropic Claude) - powers the shopping assistant, natural-language
# search, and AI-assisted product descriptions in the admin panel
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5
AI_MAX_TOKENS=1024